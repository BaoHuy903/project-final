<%- include('../partials/header') %>

<div class="calendar-container">
    <div class="calendar-sidebar">
        <button class="btn btn-primary w-100 mb-4" onclick="openNewTaskModal()" style="background-color: #4285f4; border: none; border-radius: 24px; font-weight: 500; padding: 10px 24px;">
            <span style="margin-right: 8px;">+</span> Tạo công việc
        </button>

        <div id="mini-calendar" style="margin-bottom: 20px;"></div>

        <div class="task-list">
            <h5 style="color: #5f6368; font-size: 14px; font-weight: 500; margin-bottom: 12px;">Công việc sắp tới</h5>
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.slice(0, 5).forEach(task => { %>
                    <div class="task-item" onclick="goToDate('<%= task.date %>')">
                        <div class="task-dot" data-color="<%= getColorByStatus(task.status) %>"></div>
                        <div class="task-info">
                            <div class="task-title"><%= task.title %></div>
                            <div class="task-date"><%= new Date(task.date).toLocaleDateString('vi-VN') %> - <%= task.time %></div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: #9aa0a6; font-size: 13px;">Không có công việc</p>
            <% } %>
        </div>
    </div>

    <div class="calendar-main">
        <div id="calendar"></div>
    </div>
</div>

<!-- Modal: Thêm công việc -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm công việc</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/new" method="POST" enctype="multipart/form-data" id="taskForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-500">Tiêu đề công việc</label>
                        <input type="text" class="form-control" name="title" required style="border-radius: 8px; border: 1px solid #dadce0;">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-500">Mô tả</label>
                        <textarea class="form-control" name="description" rows="3" style="border-radius: 8px; border: 1px solid #dadce0;"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Ngày bắt đầu</label>
                            <input type="date" class="form-control" name="date" required style="border-radius: 8px; border: 1px solid #dadce0;">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Giờ bắt đầu</label>
                            <input type="time" class="form-control" name="time" required style="border-radius: 8px; border: 1px solid #dadce0;">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Ngày kết thúc</label>
                            <input type="date" class="form-control" name="endDate" style="border-radius: 8px; border: 1px solid #dadce0;">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Giờ kết thúc</label>
                            <input type="time" class="form-control" name="endTime" style="border-radius: 8px; border: 1px solid #dadce0;">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Thông báo trước</label>
                            <select class="form-control" name="reminder" style="border-radius: 8px; border: 1px solid #dadce0;">
                                <option value="0">Không thông báo</option>
                                <option value="10">10 phút</option>
                                <option value="15">15 phút</option>
                                <option value="30">30 phút</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-500">Trạng thái</label>
                            <select class="form-control" name="status" style="border-radius: 8px; border: 1px solid #dadce0;">
                                <option value="Cần làm">Cần làm</option>
                                <option value="Đang làm">Đang làm</option>
                                <option value="Hoàn thành">Hoàn thành</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-500">Đính kèm</label>
                        <input type="file" name="attachments" class="form-control" multiple>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary" style="background-color: #4285f4; border: none;">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Chi tiết công việc -->
<div class="modal fade" id="taskDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Chi tiết công việc</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="taskDetailContent"></div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" id="editTaskBtn" style="background-color: #4285f4; border: none;">Sửa</button>
                <button type="button" class="btn btn-danger" id="deleteTaskBtn">Xóa</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>

<script>
    // Dữ liệu task từ server
    const tasksData = [
        <% if (tasks && tasks.length > 0) { %>
            <% tasks.forEach((task, index) => { %>
                {
                    id: "<%= task._id %>",
                    title: <%- JSON.stringify(task.title) %>,
                    date: "<%= task.date ? new Date(task.date).toISOString().split('T')[0] : '' %>",
                    endDate: "<%= task.endDate ? new Date(task.endDate).toISOString().split('T')[0] : '' %>",
                    time: "<%= task.time || '00:00' %>",
                    endTime: "<%= task.endTime || '' %>",
                    reminder: <%= task.reminder || 0 %>,
                    description: <%- JSON.stringify(task.description) %>,
                    status: "<%= task.status %>",
                    color: "<%= getColorByStatus(task.status) %>",
                    attachments: "<%= task.attachments ? task.attachments.join(',') : '' %>",
                    creatorId: "<%= task.user && task.user._id ? task.user._id.toString() : '' %>",
                    creatorName: "<%= task.user && task.user.username ? task.user.username : 'Unknown' %>",
                    currentUserId: "<%= currentUserId %>",
                    visibility: "<%= task.visibility %>",
                    comments: <%- JSON.stringify(task.comments || []) %>
                }<%= index < tasks.length - 1 ? ',' : '' %>
            <% }) %>
        <% } %>
    ];

    //tách sự kiện nhiều ngày thành từng ngày
    window.tasksData = (function() {
        const result = [];

        tasksData.forEach(task => {
            const hasEndTime = task.endTime && task.endTime.trim() !== '';
            const isMultiDay = task.endDate && task.endDate !== task.date;

            const sharedProps = {
                description: task.description,
                status: task.status,
                time: task.time,
                endTime: task.endTime,
                endDate: task.endDate,
                reminder: task.reminder,
                attachments: task.attachments,
                creatorId: task.creatorId,
                creatorName: task.creatorName,
                currentUserId: task.currentUserId,
                visibility: task.visibility,
                comments: task.comments
            };

            if (isMultiDay) {
                // Sự kiện nhiều ngày: tách thành từng ngày riêng biệt
                const startDate = new Date(task.date + 'T00:00:00');
                const endDate = new Date(task.endDate + 'T00:00:00');
                const displayTime = task.time || '00:00';

                const current = new Date(startDate);
                while (current <= endDate) {
                    const dateStr = current.toISOString().split('T')[0];
                    let dayStart, dayEnd;

                    if (task.time && task.time !== '00:00') {
                        dayStart = dateStr + 'T' + displayTime + ':00';
                        const endH = parseInt(displayTime.split(':')[0]) + 1;
                        dayEnd = dateStr + 'T' + String(Math.min(endH, 23)).padStart(2, '0') + ':' + displayTime.split(':')[1] + ':00';
                    } else {
                        dayStart = dateStr;
                        const nextDay = new Date(current);
                        nextDay.setDate(nextDay.getDate() + 1);
                        dayEnd = nextDay.toISOString().split('T')[0];
                    }

                    result.push({
                        id: task.id,
                        title: task.title,
                        start: dayStart,
                        end: dayEnd,
                        allDay: (!task.time || task.time === '00:00'),
                        backgroundColor: task.color,
                        borderColor: task.color,
                        display: 'block',
                        extendedProps: sharedProps
                    });

                    current.setDate(current.getDate() + 1);
                }
            } else if (hasEndTime) {
                // Sự kiện cùng ngày có giờ bắt đầu và kết thúc
                result.push({
                    id: task.id,
                    title: task.title,
                    start: task.date + 'T' + task.time + ':00',
                    end: task.date + 'T' + task.endTime + ':00',
                    allDay: false,
                    backgroundColor: task.color,
                    borderColor: task.color,
                    extendedProps: sharedProps
                });
            } else if (task.time && task.time !== '00:00') {
                // Sự kiện cùng ngày chỉ có giờ bắt đầu
                const endH = parseInt(task.time.split(':')[0]) + 1;
                result.push({
                    id: task.id,
                    title: task.title,
                    start: task.date + 'T' + task.time + ':00',
                    end: task.date + 'T' + String(Math.min(endH, 23)).padStart(2, '0') + ':00:00',
                    allDay: false,
                    backgroundColor: task.color,
                    borderColor: task.color,
                    extendedProps: sharedProps
                });
            } else {
                // Sự kiện cả ngày
                const nextDay = new Date(task.date + 'T00:00:00');
                nextDay.setDate(nextDay.getDate() + 1);
                result.push({
                    id: task.id,
                    title: task.title,
                    start: task.date,
                    end: nextDay.toISOString().split('T')[0],
                    allDay: true,
                    backgroundColor: task.color,
                    borderColor: task.color,
                    extendedProps: sharedProps
                });
            }
        });

        return result;
    })();
</script>

<script src="/js/calendar.js"></script>

<%- include('../partials/footer') %>