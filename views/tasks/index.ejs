<%- include('../partials/header') %>

<% 
    let progressPercent = totalTasksCount === 0 ? 0 : Math.round((completedTasksCount / totalTasksCount) * 100);
%>

<div class="p-5 bg-primary text-white text-center mb-4">
    <h1 class="display-5 fw-bold">Chào mừng bạn đến với Task Manager</h1>
    <p class="lead">Nâng cao năng suất, quản lý công việc hiệu quả và dễ dàng hơn.</p>
</div>

<div class="container mb-5">
    
    <% if (totalTasksCount > 0) { %>
        <div class="card shadow-sm mb-4 border-0 bg-light">
            <div class="card-body">
                <h6 class="fw-bold mb-2">Tiến độ tổng thể: <%= progressPercent %>% (<%= completedTasksCount %>/<%= totalTasksCount %> công việc)</h6>
                <div class="progress" style="height: 20px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: <%= progressPercent %>%" aria-valuenow="<%= progressPercent %>" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        </div>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sách công việc</h2>
        <a href="/new" class="btn btn-success fw-bold">+ Thêm công việc</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body bg-light">
            <form action="/" method="GET" class="row g-2 align-items-center">
                <div class="col-md-5">
                    <input type="text" name="search" class="form-control" placeholder="Tìm tên công việc..." value="<%= search %>">
                </div>
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="Tất cả" <%= currentStatus === 'Tất cả' ? 'selected' : '' %>>Tất cả trạng thái</option>
                        <option value="Chưa làm" <%= currentStatus === 'Chưa làm' ? 'selected' : '' %>>Chưa làm</option>
                        <option value="Đang làm" <%= currentStatus === 'Đang làm' ? 'selected' : '' %>>Đang làm</option>
                        <option value="Hoàn thành" <%= currentStatus === 'Hoàn thành' ? 'selected' : '' %>>Hoàn thành</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc / Tìm</button>
                    <a href="/" class="btn btn-outline-secondary">Xóa lọc</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <% if (tasks.length === 0) { %>
            <div class="col-12"><div class="alert alert-info">Không tìm thấy công việc nào!</div></div>
        <% } else { %>
            <% tasks.forEach(task => { %>
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100 border-<%= task.status === 'Hoàn thành' ? 'success' : 'light' %>">
                        <div class="card-body">
                            <h5 class="card-title fw-bold"><%= task.title %></h5>
                            <p class="card-text text-muted mb-2"><%= task.description || 'Không có mô tả' %></p>
                            
                            <% if (task.dueDate) { %>
                                <% 
                                    const today = new Date();
                                    const isOverdue = new Date(task.dueDate) < today && task.status !== 'Hoàn thành';
                                %>
                                <p class="mb-2" style="font-size: 0.9rem;">
                                    <span class="fw-bold">Hạn chót:</span> 
                                    <span class="<%= isOverdue ? 'text-danger fw-bold' : 'text-primary' %>">
                                        <%= new Date(task.dueDate).toLocaleDateString('vi-VN') %>
                                        <%= isOverdue ? '(Đã quá hạn)' : '' %>
                                    </span>
                                </p>
                            <% } %>

                            <span class="badge bg-<%= task.status === 'Hoàn thành' ? 'success' : (task.status === 'Đang làm' ? 'warning text-dark' : 'secondary') %>">
                                <%= task.status %>
                            </span>
                        </div>
                        <div class="card-footer bg-white d-flex justify-content-between">
                            <a href="/edit/<%= task._id %>" class="btn btn-sm btn-primary px-3">Sửa</a>
                            <form action="/delete/<%= task._id %>" method="POST" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                                <button type="submit" class="btn btn-sm btn-danger px-3">Xóa</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('../partials/footer') %>