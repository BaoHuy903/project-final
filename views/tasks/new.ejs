<%- include('../partials/header') %>

<div class="container mt-5 mb-5" style="max-width: 650px;">

    <!-- TITLE -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">➕ Thêm công việc</h2>
        <p class="text-muted mb-0">Tạo task mới để quản lý công việc hiệu quả hơn</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

            <form action="/new" method="POST">

                <!-- TITLE -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Tên công việc <span class="text-danger">*</span>
                    </label>
                    <input type="text" name="title"
                        class="form-control rounded-pill px-3"
                        placeholder="Nhập tên công việc..."
                        required>
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mô tả</label>
                    <textarea name="description"
                        class="form-control rounded-3 px-3"
                        rows="3"
                        placeholder="Mô tả chi tiết (nếu có)..."></textarea>
                </div>

                <!-- STATUS + DATE -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Trạng thái</label>
                        <select name="status" class="form-select rounded-pill">
                            <option value="Chưa làm">⏳ Chưa làm</option>
                            <option value="Đang làm">🚧 Đang làm</option>
                            <option value="Hoàn thành">✅ Hoàn thành</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Hạn chót</label>
                        <input type="date" name="dueDate"
                            class="form-control rounded-pill">
                    </div>
                </div>

                <!-- BUTTON -->
                <div class="d-flex justify-content-between mt-4">
                    <a href="/" class="btn btn-outline-secondary rounded-pill px-4">
                        ← Quay lại
                    </a>

                    <button type="submit"
                        class="btn btn-success rounded-pill px-4 shadow-sm">
                        💾 Lưu công việc
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- CSS thêm -->
<style>
.card {
    transition: all 0.25s ease;
}

.card:hover {
    transform: translateY(-3px);
}

input:focus, textarea:focus, select:focus {
    box-shadow: 0 0 0 0.15rem rgba(13,110,253,.25);
    border-color: #86b7fe;
}
</style>

<%- include('../partials/footer') %>