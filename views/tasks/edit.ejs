<%- include('../partials/header') %>

<div class="container mt-4 mb-5" style="max-width: 600px;">
    <h2>Cập nhật công việc</h2>
    <form action="/edit/<%= task._id %>" method="POST" class="mt-3">
        <div class="mb-3">
            <label class="form-label">Tên công việc <span class="text-danger">*</span></label>
            <input type="text" name="title" class="form-control" value="<%= task.title %>" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Mô tả</label>
            <textarea name="description" class="form-control" rows="3"><%= task.description %></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Ngày <span class="text-danger">*</span></label>
            <input type="date" name="date" class="form-control" value="<%= task.date ? new Date(task.date).toISOString().split('T')[0] : '' %>" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Trạng thái</label>
            <select name="status" class="form-select">
                <option value="Cần làm" <%= task.status === 'Cần làm' ? 'selected' : '' %>>Cần làm</option>
                <option value="Đang làm" <%= task.status === 'Đang làm' ? 'selected' : '' %>>Đang làm</option>
                <option value="Hoàn thành" <%= task.status === 'Hoàn thành' ? 'selected' : '' %>>Hoàn thành</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a href="/" class="btn btn-secondary">Hủy</a>
    </form>
</div>

<%- include('../partials/footer') %>