<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Calendar Clone - Task Manager</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FullCalendar CSS -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm" style="border-bottom: 1px solid #dadce0;">
    <div class="container-fluid px-3">
        <a class="navbar-brand fw-bold fs-5" href="/" style="color: #5f6368; font-family: 'Roboto', sans-serif;">
            <span style="color: #4285f4;">G</span><span style="color: #ea4335;">o</span><span style="color: #fbbc04;">o</span><span style="color: #34a853;">g</span><span style="color: #ea4335;">l</span><span style="color: #4285f4;">e</span>
            Calendar
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <% if (locals.username) { %>
                <div class="ms-auto d-flex align-items-center">
                    <span class="me-3" style="color: #5f6368; font-size: 14px;">Xin chào, <strong><%= username %></strong>!</span>
                    <a href="/users/logout" class="btn btn-outline-danger btn-sm">Đăng xuất</a>
                </div>
            <% } else { %>
                <div class="ms-auto d-flex align-items-center">
                    <a href="/users/login" class="btn btn-outline-secondary btn-sm me-2">Đăng nhập</a>
                    <a href="/users/register" class="btn" style="background-color: #4285f4; color: white; border: none;" class="btn-sm">Đăng ký</a>
                </div>
            <% } %>
        </div>
    </div>
</nav>