<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- FullCalendar CSS -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/style.css">
</head>

<body style="font-family: 'Roboto', sans-serif;">

<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm" 
     style="border-bottom: 1px solid #e5e7eb;">
    
    <div class="container-fluid px-3">

        <!-- LOGO -->
        <a class="navbar-brand fw-bold fs-5 d-flex align-items-center gap-2" href="/">
            <i class="bi bi-check2-square-fill" style="color: #6366f1; font-size: 1.5rem;"></i>
            <span>
                <span style="color:#111827;">Task</span> 
                <span style="color:#6366f1;">Manager</span>
            </span>
        </a>

        <!-- TOGGLE -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- RIGHT SIDE -->
        <div class="collapse navbar-collapse" id="navbarNav">
            
            <% if (locals.username) { %>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span style="color: #6b7280; font-size: 14px;">
                        Xin chào, <strong><%= username %></strong>
                    </span>
                    <a href="/users/logout" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                        Đăng xuất
                    </a>
                </div>
            <% } else { %>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <a href="/users/login" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        Đăng nhập
                    </a>
                    <a href="/users/register" class="btn btn-primary btn-sm rounded-pill px-3">
                        Đăng ký
                    </a>
                </div>
            <% } %>

        </div>
    </div>
</nav>