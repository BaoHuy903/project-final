<%- include('../partials/header') %>

<div class="d-flex align-items-center justify-content-center vh-100"
     style="background: linear-gradient(135deg, #4facfe, #00f2fe);">

    <div class="card border-0 shadow-lg rounded-4 p-4" style="width: 100%; max-width: 400px;">

        <!-- TITLE -->
        <div class="text-center mb-4">
            <h3 class="fw-bold">🔐 Đăng nhập</h3>
            <p class="text-muted mb-0">Chào mừng bạn quay trở lại</p>
        </div>

        <!-- ERROR -->
        <% if (error) { %>
            <div class="alert alert-danger rounded-3 text-center">
                <%= error %>
            </div>
        <% } %>

        <!-- FORM -->
        <form action="/users/login" method="POST">

            <!-- USERNAME -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Tên đăng nhập</label>
                <input type="text" name="username"
                       class="form-control rounded-pill px-3"
                       placeholder="Nhập username..."
                       required>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Mật khẩu</label>
                <input type="password" name="password"
                       class="form-control rounded-pill px-3"
                       placeholder="Nhập mật khẩu..."
                       required>
            </div>

            <!-- BUTTON -->
            <button type="submit"
                    class="btn btn-primary w-100 rounded-pill shadow-sm">
                🚀 Đăng nhập
            </button>
        </form>

        <!-- REGISTER -->
        <div class="text-center mt-3">
            <small class="text-muted">
                Chưa có tài khoản?
                <a href="/users/register" class="fw-semibold text-decoration-none">
                    Đăng ký ngay
                </a>
            </small>
        </div>

    </div>
</div>

<!-- CSS -->
<style>
input:focus {
    box-shadow: 0 0 0 0.15rem rgba(13,110,253,.25);
    border-color: #86b7fe;
}

.card {
    transition: all 0.25s ease;
}

.card:hover {
    transform: translateY(-5px);
}
</style>

<%- include('../partials/footer') %>